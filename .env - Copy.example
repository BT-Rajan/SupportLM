# --- Database ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=knowledgelm
DB_USER=knowledgelm_user
DB_PASSWORD=changeme

# --- Chat LLM provider (DeepSeek) ---
LLM_API_KEY=your-deepseek-api-key
LLM_CHAT_MODEL=deepseek-chat

# --- Embeddings ---
# Runs LOCALLY via sentence-transformers — no API key needed.
# DeepSeek does not offer a public embeddings endpoint, so this is
# intentionally separate from the chat provider above.
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- App ---
APP_SECRET_KEY=changeme-generate-a-real-random-value
APP_ENV=development

# --- SMTP (anonymous chat transcript email, Phase 2 WBS 4.2) ---
# Leave SMTP_HOST empty to disable transcript email — the endpoint
# will 400 with a clear "not configured" message instead of silently
# no-op'ing, so it's obvious in dev that this feature is off.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true
